# Local PostgreSQL:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/alwasl_digital?schema=public"
# DigitalOcean managed PostgreSQL with Prisma pg adapter:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:25060/alwasl_digital?sslmode=require&uselibpqcompat=true&schema=public"
# DigitalOcean App Platform app ID used by bun run ops:check-ownership. This is not a secret.
DO_APP_ID=""
# DigitalOcean database cluster ID used by bun run ops:check-backups. This is not a secret.
DO_DATABASE_CLUSTER_ID=""
# Maximum acceptable age for the latest automated managed database backup.
BACKUP_MAX_AGE_HOURS="30"
# Technical ownership verification. These values are identifiers, not secrets.
OWNERSHIP_CUSTOMER_LEGAL_NAME=""
OWNERSHIP_EXPECTED_DIGITALOCEAN_ACCOUNT_EMAIL=""
OWNERSHIP_EXPECTED_GITHUB_OWNER=""
OWNERSHIP_CUSTOMER_DOMAIN=""
OWNERSHIP_EXPECTED_DOMAIN_TARGET=""

# Required secret for OTP hashing. Generate with: openssl rand -hex 32
OTP_PEPPER=""

# OTP delivery
# Preferred production route: direct WAHA WhatsApp delivery through WAHA_BASE_URL/WAHA_API_KEY/WAHA_SESSION below.
# Optional fallback: point this to a legacy WhatsApp/SMS relay endpoint that accepts { phone, code, channel }.
OTP_WEBHOOK_URL=""
OTP_WEBHOOK_TOKEN=""
OTP_CHANNEL="whatsapp"

# Admin seed
SEED_ADMIN_PHONE="+9647812345678"
EXPOSE_OTP_IN_RESPONSE="false"

# Scheduled job runner. Use as Bearer token or x-cron-secret for /api/jobs/provider-retries.
CRON_SECRET=""

# Monitoring and log retention
LOG_RETENTION_DAYS="30"
# Optional external monitoring/error collector webhooks. Keep provider-specific tokens in the URL secret value.
MONITORING_ERROR_WEBHOOK_URL=""
MONITORING_STATUS_WEBHOOK_URL=""

# Local development only. Demo auth is ignored when NODE_ENV=production.
ENABLE_DEMO_AUTH="false"
# DEMO_OTP=""

# Local development only. Fake payment mutation APIs are ignored when NODE_ENV=production.
ENABLE_FAKE_PAYMENTS="false"

# WAHO provider adapter
# Local development only. Mock WAHO is ignored when NODE_ENV=production.
ENABLE_MOCK_WAHO="false"
# Optional native WAHO API contract placeholders.
WAHO_API_BASE_URL=""
WAHO_API_KEY=""
# Initial seeded provider-account balance used for routing capacity; keep real balances managed operationally after seed.
WAHO_PROVIDER_INITIAL_BALANCE="100000000"
# Provider low-balance alerts. WhatsApp is optional; admin alerts are always stored.
WAHO_PROVIDER_LOW_BALANCE_THRESHOLD="10000000"
PROVIDER_ALERT_WHATSAPP_PHONE=""

# WAHA WhatsApp bridge for OTP delivery and WAHO top-up fulfillment requests.
WAHA_BASE_URL=""
WAHA_API_KEY=""
WAHA_SESSION="default"
# Optional: configure this to send paid WAHO top-up requests to an operator/agent via WhatsApp.
WAHO_FULFILLMENT_PHONE=""
